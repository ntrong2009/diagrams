                </mxCell>
                <mxCell id="host" value="HOST: gridsz-client&#xa;(http://localhost:4200)&#xa;&#xa;module-federation.config.ts&#xa;• name: &#39;gridsz-client&#39;&#xa;• remotes: [] (registered at runtime)&#xa;• shared: @angular/*, rxjs, zone.js,&#xa;  @ngrx/*, @angular/cdk, material,&#xa;  moment, leaflet, ..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
