                <mxCell id="remote" value="REMOTE: gridsz-module-ac&#xa;(http://localhost:4201)&#xa;&#xa;module-federation.config.ts&#xa;• exposes:&#xa;    &#39;./AcModule&#39;, &#39;./ADMModule&#39;,&#xa;    &#39;./ACEngineBoostModule&#39;,&#xa;    &#39;./AddressConnectionComponent&#39;,&#xa;    &#39;./DialogCreatePolygonComponent&#39;&#xa;• shared: SAME set as host" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="460" y="220" width="340" height="200" as="geometry"/>
