        <mxCell id="p3note" value="Phase 3 — Browser executes the script and exfiltrates victim's data" style="text;html=1;align=left;fontSize=11;fontStyle=2;fontColor=#b91c1c;" vertex="1" parent="1">
          <mxGeometry x="40" y="515" width="500" height="20" as="geometry" />
