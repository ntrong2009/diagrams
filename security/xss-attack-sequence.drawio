        <mxCell id="att" value="Attacker" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=13;fontStyle=1;fillColor=#ffc9c9;strokeColor=#ef4444;size=40;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="110" height="560" as="geometry" />
        </mxCell>
        <mxCell id="abrw" value="Attacker Browser" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=13;fontStyle=1;fillColor=#fde0e0;strokeColor=#ef4444;size=40;" vertex="1" parent="1">
          <mxGeometry x="180" y="70" width="130" height="560" as="geometry" />
