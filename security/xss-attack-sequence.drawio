        <mxCell id="vbrw" value="Victim Browser" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=13;fontStyle=1;fillColor=#d0bfff;strokeColor=#8b5cf6;size=40;" vertex="1" parent="1">
          <mxGeometry x="480" y="70" width="130" height="560" as="geometry" />
        </mxCell>
        <mxCell id="srv" value="Web Server" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=13;fontStyle=1;fillColor=#ffd8a8;strokeColor=#f59e0b;size=40;" vertex="1" parent="1">
          <mxGeometry x="640" y="70" width="160" height="560" as="geometry" />
        </mxCell>
        <mxCell id="db" value="Database" style="shape=umlLifeline;perimeter=lifelinePerimeter;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fontSize=13;fontStyle=1;fillColor=#c3fae8;strokeColor=#06b6d4;size=40;" vertex="1" parent="1">
          <mxGeometry x="830" y="70" width="130" height="560" as="geometry" />
        </mxCell>
        <mxCell id="p1note" value="Phase 1 — Attacker injects payload via a normal form submission" style="text;html=1;align=left;fontSize=11;fontStyle=2;fontColor=#b91c1c;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="500" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="types &lt;script&gt; in input field" style="html=1;endArrow=block;strokeColor=#ef4444;fontColor=#b91c1c;fontSize=12;" edge="1" parent="1">
