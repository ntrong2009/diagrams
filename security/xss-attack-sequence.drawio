        <mxCell id="exec" value="render &amp; execute &lt;script&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#8b5cf6;fontColor=#6d28d9;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="485" y="543" width="120" height="26" as="geometry" />
