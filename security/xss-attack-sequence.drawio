        </mxCell>
        <mxCell id="sub" value="Attacker submits a payload through a normal form; victim's browser later loads and executes it" style="text;html=1;align=center;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="180" y="40" width="740" height="20" as="geometry" />
