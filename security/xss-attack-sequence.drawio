        <mxCell id="m9" value="6. Steals cookies / session → attacker" style="html=1;endArrow=block;strokeColor=#ef4444;strokeWidth=2;fontColor=#b91c1c;fontSize=12;fontStyle=1;" edge="1" parent="1">
