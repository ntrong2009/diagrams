                <mxCell id="det-before" value="❌ TRƯỚC KHI MERGE&#xa;━━━━━━━━━━━━━━━━━&#xa;Client → GET /tasks (200ms)&#xa;Client → GET /users (180ms)&#xa;Client → GET /assets (220ms)&#xa;Client → GET /notifications (150ms)&#xa;━━━━━━━━━━━━━━━━━&#xa;Tổng: 4 round-trip ≈ 750ms&#xa;4× overhead TCP/TLS/Auth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#C0392B;strokeWidth=2;fontSize=12;align=left;spacingLeft=15;spacingTop=10;" parent="1" vertex="1">
