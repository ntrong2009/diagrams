                </mxCell>
                <mxCell id="P3C1" value="&lt;b style=&quot;font-size: 13px; color: rgb(126, 34, 206);&quot;&gt;🔄 Change Detection&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;OnPush Strategy (skip không cần thiết)&lt;/li&gt;&lt;li&gt;Zoneless (provideZonelessChangeDetection)&lt;/li&gt;&lt;li&gt;trackBy / @for track (DOM diff thông minh)&lt;/li&gt;&lt;li&gt;Pure Pipe (tránh re-compute)&lt;/li&gt;&lt;li&gt;runOutsideAngular (skip Zone)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7e22ce;strokeWidth=2;fontSize=11;fontColor=#3b0764;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=0;" parent="1" vertex="1">
