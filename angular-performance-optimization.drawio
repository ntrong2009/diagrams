                <mxCell id="P0C5" value="&lt;b style=&quot;font-size: 13px; color: rgb(21, 128, 61);&quot;&gt;🚀 Ship &amp;amp; Deploy&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Push artifacts → Container Registry&lt;/li&gt;&lt;li&gt;Upload sourcemap → Sentry / Datadog&lt;/li&gt;&lt;li&gt;Invalidate CDN cache (selective)&lt;/li&gt;&lt;li&gt;Helm / GitHub Actions deploy&lt;/li&gt;&lt;li&gt;Canary / blue-green release&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803d;strokeWidth=2;fontSize=11;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=0;" parent="1" vertex="1">
