                <mxCell id="P1C1" value="&lt;b style=&quot;font-size: 13px; color: rgb(3, 105, 161);&quot;&gt;🌐 CDN &amp;amp; Compression&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;CDN edge (Cloudflare / GCP CDN)&lt;/li&gt;&lt;li&gt;Gzip / Brotli (giảm 60-80% size)&lt;/li&gt;&lt;li&gt;HTTP/2 - HTTP/3 / QUIC&lt;/li&gt;&lt;li&gt;TLS 1.3 (0-RTT handshake)&lt;/li&gt;&lt;li&gt;Edge Functions / Workers (geo route)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0369a1;strokeWidth=2;fontSize=11;fontColor=#0c4a6e;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=0;" parent="1" vertex="1">
