                </mxCell>
                <mxCell id="P3C3" value="&lt;b style=&quot;font-size: 13px; color: rgb(126, 34, 206);&quot;&gt;🧵 Compute Offload (INP)&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Web Worker (offload CPU heavy)&lt;/li&gt;&lt;li&gt;OffscreenCanvas (vẽ ngoài main thread)&lt;/li&gt;&lt;li&gt;WebAssembly (CPU-bound logic)&lt;/li&gt;&lt;li&gt;requestIdleCallback / Scheduler.postTask&lt;/li&gt;&lt;li&gt;Break long tasks (&amp;gt; 50ms) bằng yield&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7e22ce;strokeWidth=2;fontSize=11;fontColor=#3b0764;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=0;" parent="1" vertex="1">
                    <mxGeometry x="-2140" y="538" width="280" height="170" as="geometry"/>
