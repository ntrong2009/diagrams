<mxfile host="65bd71144e">
    <diagram id="angular-perf-3-phases" name="Angular Performance — 4 Phases">
        <mxGraphModel dx="930" dy="690" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="1300" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="🎯 ANGULAR PERFORMANCE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;fontColor=#0F172A;fontFamily=Helvetica;" parent="1" vertex="1">
                    <mxGeometry x="500" y="20" width="2200" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="P0H" value="&lt;b style=&quot;font-size:18px;&quot;&gt;CI/CD BUILD-TIME&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 12px; color: rgb(20, 83, 45);&quot;&gt;Compile · Bundle · Audit · Gate · Ship&lt;/span&gt;&lt;br&gt;&lt;br&gt;🎯 &lt;b&gt;Mục đích:&lt;/b&gt; Build artifacts tốt nhất có thể&lt;br&gt;⚙️ &lt;b&gt;Khi nào:&lt;/b&gt; TRƯỚC khi user request (deploy-time)" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;strokeWidth=3;fontSize=12;fontColor=#14532d;align=center;verticalAlign=middle;spacingLeft=12;spacingRight=12;fontFamily=Helvetica;shadow=1;gradientColor=#bbf7d0;gradientDirection=south;" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="760" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="P0C1" value="&lt;b style=&quot;font-size: 13px; color: rgb(21, 128, 61);&quot;&gt;🔨 Compile&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;AOT Compilation (ng build)&lt;/li&gt;&lt;li&gt;TypeScript strict mode&lt;/li&gt;&lt;li&gt;Minify + mangle + scope hoisting&lt;/li&gt;&lt;li&gt;Production configuration&lt;/li&gt;&lt;li&gt;Source map generation&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803d;strokeWidth=1.5;fontSize=11;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="235" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P0C2" value="&lt;b style=&quot;font-size: 13px; color: rgb(21, 128, 61);&quot;&gt;📦 Bundle &amp;amp; Optimize&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Tree-Shaking (loại dead code)&lt;/li&gt;&lt;li&gt;esbuild Builder (build nhanh 10×)&lt;/li&gt;&lt;li&gt;Code splitting (lazy chunks)&lt;/li&gt;&lt;li&gt;Asset Versioning (outputHashing=all)&lt;/li&gt;&lt;li&gt;Bundle Budget (cảnh báo size)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803d;strokeWidth=1.5;fontSize=11;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="405" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P0C3" value="&lt;b style=&quot;font-size: 13px; color: rgb(21, 128, 61);&quot;&gt;🔍 Audit &amp;amp; Gate&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Bundle Analyzer (source-map-explorer)&lt;/li&gt;&lt;li&gt;Lighthouse CI (audit headless)&lt;/li&gt;&lt;li&gt;Performance Budget Gate (block deploy)&lt;/li&gt;&lt;li&gt;ESLint perf rules · tsc --noEmit&lt;/li&gt;&lt;li&gt;Test coverage gate&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803d;strokeWidth=1.5;fontSize=11;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="575" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P0C4" value="&lt;b style=&quot;font-size: 13px; color: rgb(21, 128, 61);&quot;&gt;🚦 Prerender Build&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;SSR / SSG Build (Angular Universal)&lt;/li&gt;&lt;li&gt;Static prerender routes&lt;/li&gt;&lt;li&gt;Critical CSS extraction&lt;/li&gt;&lt;li&gt;i18n locale builds&lt;/li&gt;&lt;li&gt;Differential loading (modern/legacy)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803d;strokeWidth=1.5;fontSize=11;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="745" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P0C5" value="&lt;b style=&quot;font-size: 13px; color: rgb(21, 128, 61);&quot;&gt;🚀 Ship &amp;amp; Deploy&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Push artifacts → Container Registry&lt;/li&gt;&lt;li&gt;Upload sourcemap → Sentry / Datadog&lt;/li&gt;&lt;li&gt;Invalidate CDN cache (selective)&lt;/li&gt;&lt;li&gt;Helm / GitHub Actions deploy&lt;/li&gt;&lt;li&gt;Canary / blue-green release&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#15803d;strokeWidth=1.5;fontSize=11;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="915" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P1H" value="&lt;b style=&quot;font-size:18px;&quot;&gt;DATA LOADING&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 12px; color: rgb(12, 74, 110);&quot;&gt;Network · Bundle · Cache · Hints&lt;/span&gt;&lt;br&gt;&lt;br&gt;🎯 &lt;b&gt;Metrics:&lt;/b&gt; ↓ TTFB · ↓ FCP · ↓ network transfer&lt;br&gt;⚙️ &lt;b&gt;Nút thắt:&lt;/b&gt; latency mạng · bundle size · cache miss" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0369a1;strokeWidth=3;fontSize=12;fontColor=#0c4a6e;align=center;verticalAlign=middle;spacingLeft=12;spacingRight=12;fontFamily=Helvetica;shadow=1;gradientColor=#bae6fd;gradientDirection=south;" parent="1" vertex="1">
                    <mxGeometry x="820" y="100" width="760" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="P1C1" value="&lt;b style=&quot;font-size: 13px; color: rgb(3, 105, 161);&quot;&gt;🌐 CDN &amp;amp; Compression&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;CDN edge (Cloudflare / GCP CDN)&lt;/li&gt;&lt;li&gt;Gzip / Brotli (giảm 60-80% size)&lt;/li&gt;&lt;li&gt;HTTP/2 - HTTP/3 / QUIC&lt;/li&gt;&lt;li&gt;TLS 1.3 (0-RTT handshake)&lt;/li&gt;&lt;li&gt;Edge Functions / Workers (geo route)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0369a1;strokeWidth=1.5;fontSize=11;fontColor=#0c4a6e;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="820" y="235" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P1C3" value="&lt;b style=&quot;font-size: 13px; color: rgb(3, 105, 161);&quot;&gt;🪓 Code Splitting &amp;amp; Lazy&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Lazy Loading Routes (loadComponent)&lt;/li&gt;&lt;li&gt;Preloading Strategy (Quicklink)&lt;/li&gt;&lt;li&gt;Standalone Components&lt;/li&gt;&lt;li&gt;Module Federation (micro-frontends)&lt;/li&gt;&lt;li&gt;Asset Versioning (outputHashing)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0369a1;strokeWidth=1.5;fontSize=11;fontColor=#0c4a6e;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="820" y="405" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P1C4" value="&lt;b style=&quot;font-size: 13px; color: rgb(3, 105, 161);&quot;&gt;💾 Multi-tier Cache&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;HTTP Interceptor cache (in-app)&lt;/li&gt;&lt;li&gt;Service Worker / PWA (Cache API)&lt;/li&gt;&lt;li&gt;Browser HTTP cache (Cache-Control, ETag)&lt;/li&gt;&lt;li&gt;CDN edge cache (stale-while-revalidate)&lt;/li&gt;&lt;li&gt;Redis / API cache (BFF layer)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0369a1;strokeWidth=1.5;fontSize=11;fontColor=#0c4a6e;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="820" y="575" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P1C5" value="&lt;b style=&quot;font-size: 13px; color: rgb(3, 105, 161);&quot;&gt;🔗 Resource Hints + SSR&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;preconnect / dns-prefetch&lt;/li&gt;&lt;li&gt;preload / modulepreload (critical chunks)&lt;/li&gt;&lt;li&gt;SSR / SSG (Angular Universal)&lt;/li&gt;&lt;li&gt;103 Early Hints (server đẩy preload sớm)&lt;/li&gt;&lt;li&gt;Link Prefetching (rel=prefetch)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0369a1;strokeWidth=1.5;fontSize=11;fontColor=#0c4a6e;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="820" y="745" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P2H" value="&lt;b style=&quot;font-size:18px;&quot;&gt;CRP (Drawing UI)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 12px; color: rgb(120, 53, 15);&quot;&gt;DOM → CSSOM → Render Tree → Layout → Paint&lt;/span&gt;&lt;br&gt;&lt;br&gt;🎯 &lt;b&gt;Metrics:&lt;/b&gt; ↓ FCP · ↓ LCP · ↓ CLS&lt;br&gt;⚙️ &lt;b&gt;Nút thắt:&lt;/b&gt; render-blocking · layout shift · slow paint" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;strokeWidth=3;fontSize=12;fontColor=#78350f;align=center;verticalAlign=middle;spacingLeft=12;spacingRight=12;fontFamily=Helvetica;shadow=1;gradientColor=#fde68a;gradientDirection=south;" parent="1" vertex="1">
                    <mxGeometry x="1600" y="100" width="760" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="P2C1" value="&lt;b style=&quot;font-size: 13px; color: rgb(180, 83, 9);&quot;&gt;🖌️ Critical CSS &amp;amp; Scripts&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Inline critical CSS above-the-fold&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;font-family: Consolas, monospace;&quot;&gt;&amp;lt;script async&amp;gt;&lt;/span&gt; / &lt;span style=&quot;font-family: Consolas, monospace;&quot;&gt;defer&lt;/span&gt; (không block parse)&lt;/li&gt;&lt;li&gt;CSS containment (&lt;span style=&quot;font-family: Consolas, monospace;&quot;&gt;contain: layout&lt;/span&gt;)&lt;/li&gt;&lt;li&gt;Tránh @import CSS lồng nhau&lt;/li&gt;&lt;li&gt;Loại CSS không dùng (PurgeCSS)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b45309;strokeWidth=1.5;fontSize=11;fontColor=#78350f;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="1600" y="235" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P2C2" value="&lt;b style=&quot;font-size: 13px; color: rgb(180, 83, 9);&quot;&gt;🖼️ Image &amp;amp; Media (LCP)&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;NgOptimizedImage (priority, srcset)&lt;/li&gt;&lt;li&gt;AVIF / WebP format · responsive images&lt;/li&gt;&lt;li&gt;Lazy load images dưới fold (loading=lazy)&lt;/li&gt;&lt;li&gt;Image CDN (on-the-fly resize)&lt;/li&gt;&lt;li&gt;Fetch priority hint (fetchpriority=high)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b45309;strokeWidth=1.5;fontSize=11;fontColor=#78350f;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="1600" y="405" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P2C3" value="&lt;b style=&quot;font-size: 13px; color: rgb(180, 83, 9);&quot;&gt;🔤 Font Strategy&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;font-display: swap (tránh invisible text)&lt;/li&gt;&lt;li&gt;Preload font file critical&lt;/li&gt;&lt;li&gt;Subset font (chỉ ký tự cần dùng)&lt;/li&gt;&lt;li&gt;Self-host font (tránh CORS round trip)&lt;/li&gt;&lt;li&gt;Variable font (1 file thay nhiều weight)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b45309;strokeWidth=1.5;fontSize=11;fontColor=#78350f;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="1600" y="575" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P2C4" value="&lt;b style=&quot;font-size: 13px; color: rgb(180, 83, 9);&quot;&gt;💧 Hydration &amp;amp; @defer&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Hydration (resume từ SSR DOM)&lt;/li&gt;&lt;li&gt;Incremental Hydration (Angular 19+)&lt;/li&gt;&lt;li&gt;@defer Block (viewport / idle / on interaction)&lt;/li&gt;&lt;li&gt;provideClientHydration()&lt;/li&gt;&lt;li&gt;View Transitions API&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b45309;strokeWidth=1.5;fontSize=11;fontColor=#78350f;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="1600" y="745" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P2C5" value="&lt;b style=&quot;font-size: 13px; color: rgb(180, 83, 9);&quot;&gt;📐 Layout Stability (CLS)&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Set width/height cho image, video, iframe&lt;/li&gt;&lt;li&gt;Reserve space cho ad / embed&lt;/li&gt;&lt;li&gt;Tránh inserting content above existing&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;font-family: Consolas, monospace;&quot;&gt;contain-intrinsic-size&lt;/span&gt; cho placeholder&lt;/li&gt;&lt;li&gt;Tránh layout thrashing (batch read/write)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b45309;strokeWidth=1.5;fontSize=11;fontColor=#78350f;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="1600" y="915" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P3H" value="&lt;b style=&quot;font-size:18px;&quot;&gt;Browser&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 12px; color: rgb(59, 7, 100);&quot;&gt;Change Detection · CPU · RAM · UX response&lt;/span&gt;&lt;br&gt;&lt;br&gt;🎯 &lt;b&gt;Metrics:&lt;/b&gt; ↓ INP · ↓ TBT · ↓ long tasks&lt;br&gt;⚙️ &lt;b&gt;Nút thắt:&lt;/b&gt; re-render · long JS tasks · memory leak" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#7e22ce;strokeWidth=3;fontSize=12;fontColor=#3b0764;align=center;verticalAlign=middle;spacingLeft=12;spacingRight=12;fontFamily=Helvetica;shadow=1;gradientColor=#e9d5ff;gradientDirection=south;" parent="1" vertex="1">
                    <mxGeometry x="2380" y="100" width="760" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="P3C1" value="&lt;b style=&quot;font-size: 13px; color: rgb(126, 34, 206);&quot;&gt;🔄 Change Detection&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;OnPush Strategy (skip không cần thiết)&lt;/li&gt;&lt;li&gt;Zoneless (provideZonelessChangeDetection)&lt;/li&gt;&lt;li&gt;trackBy / @for track (DOM diff thông minh)&lt;/li&gt;&lt;li&gt;Pure Pipe (tránh re-compute)&lt;/li&gt;&lt;li&gt;runOutsideAngular (skip Zone)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7e22ce;strokeWidth=1.5;fontSize=11;fontColor=#3b0764;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="2380" y="235" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P3C2" value="&lt;b style=&quot;font-size: 13px; color: rgb(126, 34, 206);&quot;&gt;⚡ Signals &amp;amp; Reactivity&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Angular Signals (granular reactivity)&lt;/li&gt;&lt;li&gt;computed() / effect() (auto memoize)&lt;/li&gt;&lt;li&gt;input() / output() Signal&lt;/li&gt;&lt;li&gt;NgRx Memoized Selectors&lt;/li&gt;&lt;li&gt;RxJS shareReplay · distinctUntilChanged&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7e22ce;strokeWidth=1.5;fontSize=11;fontColor=#3b0764;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="2380" y="405" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P3C3" value="&lt;b style=&quot;font-size: 13px; color: rgb(126, 34, 206);&quot;&gt;🧵 Compute Offload (INP)&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Web Worker (P3C3) — offload CPU work khỏi main thread&lt;/li&gt;&lt;li&gt;OffscreenCanvas (vẽ ngoài main thread)&lt;/li&gt;&lt;li&gt;WebAssembly (CPU-bound logic)&lt;/li&gt;&lt;li&gt;requestIdleCallback / Scheduler.postTask&lt;/li&gt;&lt;li&gt;Break long tasks (&amp;gt; 50ms) bằng yield&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7e22ce;strokeWidth=1.5;fontSize=11;fontColor=#3b0764;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="2380" y="575" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P3C4" value="&lt;b style=&quot;font-size: 13px; color: rgb(126, 34, 206);&quot;&gt;📊 Virtualization &amp;amp; DOM&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Virtual Scroll (CDK cdk-virtual-scroll)&lt;/li&gt;&lt;li&gt;Immutable Updates (OnPush hoạt động đúng)&lt;/li&gt;&lt;li&gt;Control Flow @if/@for (nhanh hơn 30%)&lt;/li&gt;&lt;li&gt;HTTP Interceptor Cache · Optimistic UI&lt;/li&gt;&lt;li&gt;inject() function (gọn hơn constructor)&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7e22ce;strokeWidth=1.5;fontSize=11;fontColor=#3b0764;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="2380" y="745" width="760" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="P3C5" value="&lt;b style=&quot;font-size: 13px; color: rgb(126, 34, 206);&quot;&gt;🛡️ Memory &amp;amp; Resilience&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;AbortController / takeUntil (huỷ work)&lt;/li&gt;&lt;li&gt;RxJS retry/retryWhen + backoff&lt;/li&gt;&lt;li&gt;RxJS timeout (cap request time)&lt;/li&gt;&lt;li&gt;Circuit Breaker via interceptor state&lt;/li&gt;&lt;li&gt;catchError → fallback / cached data&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7e22ce;strokeWidth=1.5;fontSize=11;fontColor=#3b0764;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontFamily=Helvetica;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="2380" y="915" width="760" height="155" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>