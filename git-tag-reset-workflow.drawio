                        <mxPoint x="560" y="140" as="sourcePoint"/>
                        <mxPoint x="560" y="2040" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="a_github" value="GitHub (Remote)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="830" y="90" width="160" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="l_github" value="" style="endArrow=none;html=1;strokeColor=#d6b656;strokeWidth=2;dashed=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="910" y="140" as="sourcePoint"/>
                        <mxPoint x="910" y="2040" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="a_action" value="mathieudutour/&#xa;github-tag-action" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1200" y="80" width="180" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="l_action" value="" style="endArrow=none;html=1;strokeColor=#b85450;strokeWidth=2;dashed=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1290" y="140" as="sourcePoint"/>
                        <mxPoint x="1290" y="2040" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s1_header" value="Step 1 — Delete the old tag (v0.2.0) to clean up the incorrect label on the server" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="150" y="200" width="1250" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="s1_m1" value="1: git push origin :refs/tags/client-v0.2.0&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;(highest tag should be client-v0.1.146, not client-v0.2.0)&lt;/span&gt;" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="190" y="260" as="sourcePoint"/>
                        <mxPoint x="560" y="260" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s1_m2" value="2: Propagate tag deletion to remote" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="560" y="300" as="sourcePoint"/>
                        <mxPoint x="910" y="300" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s1_m3" value="3: Tag client-v0.2.0 removed" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="910" y="360" as="sourcePoint"/>
                        <mxPoint x="190" y="360" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s2_header" value="Step 2 — Manually create a new tag client-v0.1.147 (pin the milestone commit)" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="150" y="400" width="1250" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="s2_m1" value="4: git tag -a client-v0.1.147 -m &quot;Reset to standard milestone&quot; &lt;commit_id&gt;" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="190" y="460" as="sourcePoint"/>
                        <mxPoint x="560" y="460" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s2_m2" value="5: git push origin client-v0.1.147" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="190" y="500" as="sourcePoint"/>
                        <mxPoint x="910" y="500" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s2_m3" value="6: Tag client-v0.1.147 now points to the chosen commit" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="910" y="550" as="sourcePoint"/>
                        <mxPoint x="190" y="550" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s3_header" value="Step 3 — Create a new Pull Request (avoid #major / #minor keywords)" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="150" y="600" width="1250" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="s3_m1" value="7: commit &quot;fix: fix UI&quot;" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="190" y="660" as="sourcePoint"/>
                        <mxPoint x="560" y="660" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s3_m2" value="8: commit &quot;docs: update readme&quot;" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="190" y="700" as="sourcePoint"/>
                        <mxPoint x="560" y="700" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s3_m3" value="9: git push &amp; open PR targeting main" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="190" y="740" as="sourcePoint"/>
                        <mxPoint x="910" y="740" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s3_m4" value="10: Pull Request created" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="910" y="790" as="sourcePoint"/>
                        <mxPoint x="190" y="790" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s3_note" value="Note: commits must NOT contain #major or #minor to preserve the current milestone" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="260" y="810" width="520" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="s4_header" value="Step 4 — Action traces history (scans tags and commit range)" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="150" y="880" width="1250" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="s4_m1" value="11: Merge PR into main" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="190" y="940" as="sourcePoint"/>
                        <mxPoint x="910" y="940" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s4_m2" value="12: Trigger action on push/merge" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="910" y="980" as="sourcePoint"/>
                        <mxPoint x="1290" y="980" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s4_m3" value="13: Find latest tag → client-v0.1.147" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1290" y="1020" as="sourcePoint"/>
                        <mxPoint x="910" y="1020" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s4_m4" value="14: Scan commits in range client-v0.1.147..HEAD" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1290" y="1060" as="sourcePoint"/>
                        <mxPoint x="910" y="1060" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s4_self" value="15: Detects only&#xa;fix + docs&#xa;(old feat commits ignored)" style="html=1;endArrow=block;endFill=1;strokeColor=#b85450;fontSize=11;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=1;entryDx=0;entryDy=0;curved=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1340" y="1100" as="sourcePoint"/>
                        <mxPoint x="1240" y="1100" as="targetPoint"/>
                        <Array as="points">
                            <mxPoint x="1400" y="1130"/>
                            <mxPoint x="1180" y="1130"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s5_header" value="Step 5 — Build the next version (sequential patch bump)" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="150" y="1200" width="1250" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="s5_self" value="16: Decision — Patch release" style="html=1;endArrow=block;endFill=1;strokeColor=#b85450;fontSize=12;curved=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1340" y="1260" as="sourcePoint"/>
                        <mxPoint x="1240" y="1260" as="targetPoint"/>
                        <Array as="points">
                            <mxPoint x="1400" y="1290"/>
                            <mxPoint x="1180" y="1290"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s5_m1" value="17: Create tag client-v0.1.148" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1290" y="1340" as="sourcePoint"/>
                        <mxPoint x="910" y="1340" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s5_m2" value="18: Notify — version bumped to client-v0.1.148&#xa;(not 0.2.0, not back to 0.1.147)" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="910" y="1400" as="sourcePoint"/>
                        <mxPoint x="190" y="1400" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="outcome" value="&lt;b&gt;Goal achieved&lt;/b&gt;&lt;br&gt;The version continues sequentially from the milestone you manually set: &lt;code&gt;client-v0.1.147&lt;/code&gt; → &lt;code&gt;client-v0.1.148&lt;/code&gt;." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=10;spacingTop=4;" parent="1" vertex="1">
