                <mxCell id="a_local" value="Local Git" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="480" y="90" width="160" height="50" as="geometry"/>
