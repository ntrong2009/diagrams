                </mxCell>
                <mxCell id="tick_3" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="570" y="850" as="sourcePoint"/>
                        <mxPoint x="570" y="860" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="tick_3_l" value="3" style="text;html=1;fontSize=10;fontColor=#666;align=center;" parent="1" vertex="1">
                    <mxGeometry x="560" y="862" width="20" height="16" as="geometry"/>
                </mxCell>
                <mxCell id="tick_6" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="810" y="850" as="sourcePoint"/>
                        <mxPoint x="810" y="860" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="tick_6_l" value="6" style="text;html=1;fontSize=10;fontColor=#666;align=center;" parent="1" vertex="1">
                    <mxGeometry x="800" y="862" width="20" height="16" as="geometry"/>
                </mxCell>
                <mxCell id="tick_9" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1050" y="850" as="sourcePoint"/>
                        <mxPoint x="1050" y="860" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="tick_9_l" value="9" style="text;html=1;fontSize=10;fontColor=#666;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1040" y="862" width="20" height="16" as="geometry"/>
                </mxCell>

                <!-- ==================== SUMMARY COMPARISON ==================== -->
                <mxCell id="summary_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#1a1a2e;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="30" y="895" width="1430" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="summary_title" value="Key Differences" style="text;html=1;fontSize=16;fontStyle=1;fontColor=#ffffff;align=center;" parent="1" vertex="1">
                    <mxGeometry x="600" y="900" width="200" height="28" as="geometry"/>
                </mxCell>

                <!-- Concurrency summary -->
                <mxCell id="sum_conc" value="&lt;div style='text-align:center;'&gt;&lt;b style='font-size:13px;color:#4361ee'&gt;Concurrency&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:11px;color:#ccc'&gt;Multiple tasks &lt;b&gt;in progress&lt;/b&gt;&lt;br&gt;(interleaved on 1 core)&lt;br&gt;&lt;i&gt;Deals with many things at once&lt;/i&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2a2a4a;strokeColor=#4361ee;strokeWidth=2;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="60" y="932" width="260" height="80" as="geometry"/>
                </mxCell>

                <!-- Parallelism summary -->
                <mxCell id="sum_par" value="&lt;div style='text-align:center;'&gt;&lt;b style='font-size:13px;color:#f77f00'&gt;Parallelism&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:11px;color:#ccc'&gt;Multiple tasks &lt;b&gt;running simultaneously&lt;/b&gt;&lt;br&gt;(on multiple cores)&lt;br&gt;&lt;i&gt;Does many things at once&lt;/i&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2a2a4a;strokeColor=#f77f00;strokeWidth=2;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="370" y="932" width="260" height="80" as="geometry"/>
                </mxCell>

                <!-- Async summary -->
                <mxCell id="sum_async" value="&lt;div style='text-align:center;'&gt;&lt;b style='font-size:13px;color:#2ec4b6'&gt;Asynchronous&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:11px;color:#ccc'&gt;Task &lt;b&gt;doesn't block&lt;/b&gt; while waiting&lt;br&gt;(yield during I/O, callback when done)&lt;br&gt;&lt;i&gt;Doesn't waste time waiting&lt;/i&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2a2a4a;strokeColor=#2ec4b6;strokeWidth=2;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="680" y="932" width="280" height="80" as="geometry"/>
                </mxCell>

                <!-- Relationship note -->
                <mxCell id="sum_note" value="&lt;div style='text-align:center;font-size:11px;color:#ffd700'&gt;&lt;b&gt;They are not mutually exclusive!&lt;/b&gt;&lt;br&gt;&lt;span style='color:#aaa'&gt;e.g. Node.js = concurrent + async (single-threaded)&lt;br&gt;e.g. Go = concurrent + parallel (goroutines on multi-core)&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=center;rounded=1;fillColor=#2a2a4a;strokeColor=#ffd700;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="1010" y="932" width="420" height="80" as="geometry"/>
                </mxCell>

