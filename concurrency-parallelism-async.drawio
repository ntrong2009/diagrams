                <!-- Arrow: A send → I/O starts -->
                <mxCell id="s4_io_start_arrow" value="" style="endArrow=block;html=1;strokeWidth=1.5;strokeColor=#adb5bd;endFill=1;dashed=1;exitX=0.5;exitY=1;entryX=0;entryY=0.5;" parent="1" source="s4_a_send" target="s4_io_wait" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- Arrow: I/O done → callback -->
                <mxCell id="s4_io_done_arrow" value="" style="endArrow=block;html=1;strokeWidth=1.5;strokeColor=#adb5bd;endFill=1;dashed=1;exitX=1;exitY=0.5;entryX=0.5;entryY=1;" parent="1" source="s4_io_wait" target="s4_a_recv" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- "no CPU wasted!" annotation -->
                <mxCell id="s4_annotation" value="&lt;div style='text-align:center;'&gt;&lt;b style='color:#2ec4b6'&gt;Thread is NOT blocked!&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#868e96'&gt;Does useful work (Task B)&lt;br&gt;while waiting for I/O&lt;/span&gt;&lt;/div&gt;" style="text;html=1;fontSize=11;align=center;" parent="1" vertex="1">
                    <mxGeometry x="420" y="760" width="200" height="50" as="geometry"/>
                </mxCell>

                <!-- Total time indicator -->
                <mxCell id="s4_time_arrow" value="" style="endArrow=block;startArrow=block;endFill=1;startFill=1;html=1;strokeWidth=1.5;strokeColor=#2ec4b6;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="330" y="720" as="sourcePoint"/>
                        <mxPoint x="970" y="720" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="s4_time_label" value="&lt;b style='color:#2ec4b6'&gt;Total: 8 time units (saved I/O wait time!)&lt;/b&gt;" style="text;html=1;fontSize=11;align=left;verticalAlign=bottom;" parent="1" vertex="1">
                    <mxGeometry x="980" y="712" width="320" height="20" as="geometry"/>
                </mxCell>

                <!-- ==================== TIME AXIS ==================== -->
                <mxCell id="time_axis" value="" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#333;endFill=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
