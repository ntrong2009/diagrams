                </mxCell>
                <mxCell id="time_axis_label" value="&lt;b&gt;Time&lt;/b&gt;" style="text;html=1;fontSize=13;fontColor=#333;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1125" y="845" width="50" height="22" as="geometry"/>
                </mxCell>
                <!-- Time ticks -->
                <mxCell id="tick_0" value="" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="330" y="850" as="sourcePoint"/>
                        <mxPoint x="330" y="860" as="targetPoint"/>
