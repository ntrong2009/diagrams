                    </mxGeometry>
                </mxCell>
                <mxCell id="pdb_note" value="&lt;b&gt;Key points:&lt;/b&gt; PDB does &lt;b&gt;NOT&lt;/b&gt; prevent &lt;i&gt;involuntary&lt;/i&gt; disruptions (node crash, kernel panic, hardware failure) — it only gates the eviction API. &lt;b&gt;minAvailable&lt;/b&gt; ensures at least N Ready pods stay; &lt;b&gt;maxUnavailable&lt;/b&gt; caps simultaneous churn. Pair with PriorityClass + topology spread + Affinity for full availability planning. Without a PDB, &lt;code&gt;kubectl drain&lt;/code&gt; will happily evict all your replicas at once during a node upgrade." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8dc;strokeColor=#d6b656;fontSize=11;arcSize=10;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;" parent="1" vertex="1">
