                </mxCell>
                <mxCell id="pdb_evict" value="&lt;b&gt;Voluntary disruption&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#666;&#39;&gt;kubectl drain &amp;lt;node&amp;gt;&lt;br&gt;node / cluster upgrade&lt;br&gt;cluster autoscaler scale-in&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=10;" parent="1" vertex="1">
