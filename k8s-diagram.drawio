                <mxCell id="pdb_pods_note" value="&lt;font style=&#39;font-size:11px;color:#1a7a1a;&#39;&gt;2 Ready ≥ minAvailable(2) → eviction of Pod 3 is &lt;b&gt;ALLOWED&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;" parent="1" vertex="1">
