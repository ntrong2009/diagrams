                        <mxPoint x="1290" y="640" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- Self-loop on cache_new: empty dictionary -->
                <mxCell id="note_empty" value="initial state: { }  (no entries)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=2;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1180" y="670" width="220" height="26" as="geometry"/>
                </mxCell>

                <!-- 9. Pod v2 readiness probe OK -->
