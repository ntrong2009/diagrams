                <mxCell id="m4" value="4. HIT — return cached value (fast, ~1 ms)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#006600;fontSize=12;fontStyle=1;dashed=1;" parent="1" edge="1">
