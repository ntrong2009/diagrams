                <!-- 10. LB -> Pod v1: SIGTERM (drain) -->
                <mxCell id="m10" value="10. SIGTERM → drain Pod v1" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#cc0000;fontSize=12;fontStyle=1;" parent="1" edge="1">
