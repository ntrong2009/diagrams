                        <mxPoint x="830" y="800" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- BIG RED CROSS / destroyed marker on old cache lifeline -->
                <mxCell id="destroyed_box" value="✗ DESTROYED&#xa;Pod v1 container is terminated.&#xa;In-memory cache lives inside the process —&#xa;it is freed together with the process heap.&#xa;Nothing is persisted to disk." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="500" y="850" width="430" height="100" as="geometry"/>
                </mxCell>

                <!-- X marks on Pod v1 and cache_old lifelines -->
                <mxCell id="x_old_pod" value="X" style="text;html=1;fontSize=42;fontStyle=1;fontColor=#cc0000;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="580" y="1170" width="40" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="x_old_cache" value="X" style="text;html=1;fontSize=42;fontStyle=1;fontColor=#cc0000;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="810" y="1170" width="40" height="60" as="geometry"/>
                </mxCell>

                <!-- ============================================================ -->
                <!-- PHASE 3: Next request hits Pod v2 — cache MISS                -->
                <!-- ============================================================ -->

                <mxCell id="phase3" value="Phase 3 — Next request is routed to Pod v2: COLD cache, every request misses" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="120" y="1260" width="1420" height="30" as="geometry"/>
                </mxCell>

                <!-- 12. Client -> LB -->
                <mxCell id="m12" value="12. GET /api/data (same key as step 1)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#000000;fontSize=12;" parent="1" edge="1">
