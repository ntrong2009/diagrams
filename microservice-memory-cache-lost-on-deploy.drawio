                <!-- 11. Pod v1 process exits → heap freed -->
                <mxCell id="m11" value="11. process exits → heap freed by OS&#xa;     (IMemoryCache and its entries are GONE)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#cc0000;fontSize=12;fontStyle=1;" parent="1" edge="1">
