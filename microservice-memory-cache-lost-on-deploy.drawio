                <!-- 13. LB -> Pod v2 -->
                <mxCell id="m13" value="13. route to Pod v2 (only remaining replica)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#000000;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="365" y="1350" as="sourcePoint"/>
                        <mxPoint x="1060" y="1350" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 14. Pod v2 -> cache_new: TryGet -->
                <mxCell id="m14" value="14. cache.TryGetValue(key)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#000000;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1060" y="1390" as="sourcePoint"/>
                        <mxPoint x="1290" y="1390" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 15. cache_new -> Pod v2: MISS -->
                <mxCell id="m15" value="15. MISS — empty dictionary, no entry" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#cc0000;fontSize=12;fontStyle=1;dashed=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1290" y="1420" as="sourcePoint"/>
                        <mxPoint x="1060" y="1420" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 16. Pod v2 -> DB: SELECT -->
                <mxCell id="m16" value="16. SELECT * FROM ... (fallback to source of truth)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#000000;fontSize=12;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1060" y="1460" as="sourcePoint"/>
                        <mxPoint x="1480" y="1460" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 17. DB -> Pod v2: rows -->
                <mxCell id="m17" value="17. result set (slow, ~50–500 ms)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#000000;fontSize=12;dashed=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1480" y="1495" as="sourcePoint"/>
                        <mxPoint x="1060" y="1495" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 18. Pod v2 -> cache_new: Set(key, value) — rebuild -->
                <mxCell id="m18" value="18. cache.Set(key, value) — rebuild cache entry" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#006600;fontSize=12;fontStyle=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1060" y="1535" as="sourcePoint"/>
                        <mxPoint x="1290" y="1535" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 19. Pod v2 -> LB -->
                <mxCell id="m19" value="19. 200 OK (slow first response)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#000000;fontSize=12;dashed=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1060" y="1575" as="sourcePoint"/>
                        <mxPoint x="365" y="1575" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 20. LB -> Client -->
                <mxCell id="m20" value="20. 200 OK" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#000000;fontSize=12;dashed=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="365" y="1605" as="sourcePoint"/>
                        <mxPoint x="150" y="1605" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- Note: cache rebuild state -->
                <mxCell id="note3" value="Cache state on Pod v2: { key → value }  — rebuilt from scratch, one key at a time" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=2;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1080" y="1640" width="420" height="30" as="geometry"/>
                </mxCell>

                <!-- ============================================================ -->
                <!-- CONSEQUENCES SUMMARY                                          -->
                <!-- ============================================================ -->

                <mxCell id="phase4" value="Consequences after every deploy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="120" y="1720" width="1420" height="30" as="geometry"/>
                </mxCell>

                <mxCell id="cons1" value="① Cold start latency&#xa;Every endpoint runs the slow DB path until the cache warms up again." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="140" y="1770" width="320" height="80" as="geometry"/>
                </mxCell>

                <mxCell id="cons2" value="② Thundering herd on DB&#xa;If many clients hit the new pod simultaneously, all of them miss and stampede the database." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="480" y="1770" width="340" height="80" as="geometry"/>
                </mxCell>

                <mxCell id="cons3" value="③ Cache is not shared across replicas&#xa;Each replica keeps its own copy; rolling deploys ⇒ at least one replica is always cold." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="840" y="1770" width="340" height="80" as="geometry"/>
                </mxCell>

                <mxCell id="cons4" value="④ Same issue on crash / autoscale&#xa;Any pod restart, OOM-kill, or HPA scale-up resets the cache. Deploy is just the visible case." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1200" y="1770" width="340" height="80" as="geometry"/>
                </mxCell>

                <!-- ============================================================ -->
                <!-- MITIGATION                                                    -->
                <!-- ============================================================ -->

                <mxCell id="mitig_title" value="Mitigation — move state out of the process" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="120" y="1880" width="1420" height="30" as="geometry"/>
                </mxCell>

                <mxCell id="mit1" value="✓ Use a distributed cache&#xa;Redis / Memcached / Cloud Memorystore. Survives pod restarts and is shared across replicas." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="140" y="1930" width="320" height="80" as="geometry"/>
                </mxCell>

                <mxCell id="mit2" value="✓ Two-tier cache (L1 in-mem + L2 Redis)&#xa;Keep in-memory for hot reads, fall back to Redis on miss; new pod warms its L1 from L2." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="480" y="1930" width="340" height="80" as="geometry"/>
                </mxCell>

                <mxCell id="mit3" value="✓ Cache warm-up on startup&#xa;Pre-load critical keys in the readiness probe so the pod only joins the LB once it is warm." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="840" y="1930" width="340" height="80" as="geometry"/>
                </mxCell>

                <mxCell id="mit4" value="✓ Single-flight / request coalescing&#xa;Collapse concurrent misses for the same key into a single DB call to prevent stampedes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1200" y="1930" width="340" height="80" as="geometry"/>
                </mxCell>

                <!-- ============================================================ -->
                <!-- LEGEND                                                        -->
                <!-- ============================================================ -->

                <mxCell id="legend_title" value="Legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="140" y="2050" width="120" height="26" as="geometry"/>
                </mxCell>

                <mxCell id="leg_solid" value="" style="html=1;endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=2;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="280" y="2065" as="sourcePoint"/>
