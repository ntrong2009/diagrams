                <mxCell id="m7" value="7. K8s schedules Pod v2 (new image)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#0066cc;fontSize=12;fontStyle=1;" parent="1" edge="1">
