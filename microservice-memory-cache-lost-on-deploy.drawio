                <!-- 8. Pod v2 self-init: cache starts EMPTY -->
                <mxCell id="m8" value="8. process starts → new IMemoryCache instance (EMPTY)" style="html=1;endArrow=block;elbow=vertical;startArrow=none;endFill=1;strokeColor=#0066cc;fontSize=12;fontStyle=1;" parent="1" edge="1">
