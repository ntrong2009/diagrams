                <!-- Note: cache state -->
                <mxCell id="note1" value="Cache state on Pod v1: { key → value }  ✔ warm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=2;align=center;" parent="1" vertex="1">
