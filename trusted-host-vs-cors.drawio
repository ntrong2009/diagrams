                    <mxGeometry width="630" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="cors_enforce_title" value="🔒 Browser Enforcement (Same-Origin Policy)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontStyle=1;fontColor=#c62828;" parent="4" vertex="1">
                    <mxGeometry x="120" y="5" width="390" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="cors_evil" value="&lt;b&gt;evil-site.com&lt;/b&gt;&lt;br&gt;&lt;i style=&#39;font-size:10px&#39;&gt;JS tries to call&lt;br&gt;api.gridsz.com&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;strokeWidth=1;fontSize=11;" parent="4" vertex="1">
                    <mxGeometry x="20" y="50" width="140" height="70" as="geometry"/>
