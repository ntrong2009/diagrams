                <mxCell id="cors_arrow_yes" value="&lt;b style=&#39;color:#2e7d32;font-size:12px&#39;&gt;YES ✓&lt;/b&gt;" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#2e7d32;endFill=1;" parent="1" source="cors_decision" target="cors_resp_yes" edge="1">
