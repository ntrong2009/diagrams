                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cors_browser_error" value="&lt;b style=&quot;color: rgb(198, 40, 40); font-size: 14px;&quot;&gt;Browser THROWS ERROR&lt;/b&gt;&lt;br&gt;&lt;code style=&quot;color: rgb(198, 40, 40); font-size: 9px;&quot;&gt;Access to fetch at &#39;https://api.gridsz.com/api/data&#39; from origin &#39;https://evil.com&#39; has been blocked by CORS policy: No &#39;Access-Control-Allow-Origin&#39; header is present.&lt;/code&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;strokeWidth=2;fontSize=11;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="1367.5" y="540" width="272.5" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="cors_arrow_to_error" value="&lt;span style=&#39;font-size:10px&#39;&gt;Step 2: response&lt;br&gt;back to browser&lt;/span&gt;" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#c62828;endFill=1;curved=1;" parent="1" source="cors_resp_no" target="cors_browser_error" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cors_keypoints" value="&lt;div style=&#39;text-align:left;font-size:12px;&#39;&gt;&lt;b&gt;Key Characteristics:&lt;/b&gt;&lt;br&gt;• Enforced by the &lt;b&gt;browser&lt;/b&gt; (not the server)&lt;br&gt;• Validates &lt;code&gt;Origin&lt;/code&gt; header against allowed origins&lt;br&gt;• Uses &lt;b&gt;preflight&lt;/b&gt; (OPTIONS) for non-simple requests&lt;br&gt;• Server &lt;b&gt;always responds&lt;/b&gt; — browser decides to allow or block&lt;br&gt;• Protects the &lt;b&gt;user&lt;/b&gt; from malicious cross-origin scripts&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f77f00;strokeWidth=1;align=center;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1010" y="920" width="540" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="vs_circle" value="VS" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#1a1a2e;fontColor=#ffffff;fontSize=20;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="775" y="490" width="50" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="" style="group" parent="1" vertex="1" connectable="0">
                    <mxGeometry x="950" y="700" width="630" height="170" as="geometry"/>
