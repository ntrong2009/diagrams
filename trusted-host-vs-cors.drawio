                <mxCell id="cors_evil_arrow1" value="request" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#c62828;endFill=1;fontSize=10;" parent="4" source="cors_evil" target="cors_server_resp" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cors_browser_block" value="&lt;b style=&#39;color:#c62828;font-size:12px&#39;&gt;BROWSER&lt;br&gt;THROWS ERROR&lt;/b&gt;&lt;br&gt;&lt;code style=&#39;font-size:9px;color:#c62828&#39;&gt;TypeError:&lt;br&gt;Failed to fetch&lt;/code&gt;&lt;br&gt;&lt;i style=&#39;font-size:9px&#39;&gt;JS cannot read&lt;br&gt;the response&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;strokeWidth=2;fontSize=11;" parent="4" vertex="1">
                    <mxGeometry x="470" y="38" width="150" height="100" as="geometry"/>
