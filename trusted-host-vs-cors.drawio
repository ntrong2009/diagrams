                    <mxGeometry x="1447.5" y="345" width="165" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="cors_resp_no" value="&lt;div style=&#39;text-align:left;font-size:10px&#39;&gt;&lt;b&gt;Response WITHOUT&lt;br&gt;CORS headers&lt;/b&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#e63946;strokeWidth=2;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1420" y="440" width="165" height="50" as="geometry"/>
