                <mxCell id="th_keypoints" value="&lt;div style=&#39;text-align:left;font-size:12px;&#39;&gt;&lt;b&gt;Key Characteristics:&lt;/b&gt;&lt;br&gt;• Runs on the &lt;b&gt;server side&lt;/b&gt; only&lt;br&gt;• Validates &lt;code&gt;Host&lt;/code&gt; header against a whitelist&lt;br&gt;• Prevents host header poisoning &amp; cache attacks&lt;br&gt;• Request is &lt;b&gt;rejected before reaching&lt;/b&gt; the application&lt;br&gt;• Protects the &lt;b&gt;server&lt;/b&gt; from malicious requests&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#4361ee;strokeWidth=1;align=center;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="120" y="920" width="540" height="130" as="geometry"/>
