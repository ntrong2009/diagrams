                <mxCell id="cors_server_resp" value="&lt;div style=&#39;text-align:left;font-size:11px&#39;&gt;Server responds with &lt;b&gt;data&lt;/b&gt;&lt;br&gt;but &lt;b style=&#39;color:#c62828&#39;&gt;NO&lt;/b&gt; &lt;code&gt;Access-Control-Allow-Origin&lt;/code&gt;&lt;br&gt;header for evil-site.com&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#c62828;strokeWidth=1;fontSize=11;" parent="4" vertex="1">
                    <mxGeometry x="210" y="50" width="210" height="70" as="geometry"/>
