                    <mxGeometry x="880" y="310" width="750" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="cors_server_label" value="&lt;b&gt;API Server (Origin B: https://api.gridsz.com)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#2e7d32;fontStyle=1;" parent="1" vertex="1">
