                <mxCell id="titleBanner" value="" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#1e3a5f;strokeColor=#0f172a;strokeWidth=1;shadow=1;gradientColor=#3b5780;gradientDirection=south;" parent="1" vertex="1">
                    <mxGeometry x="20" y="20" width="1360" height="80" as="geometry"/>
