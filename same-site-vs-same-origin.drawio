    <diagram id="ss-vs-so" name="Same-Site vs Same-Origin">
        <mxGraphModel dx="1019" dy="797" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
