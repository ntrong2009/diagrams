                <mxCell id="title" value="Same-Site vs Same-Origin" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#ffffff;fillColor=none;strokeColor=none;fontFamily=Helvetica;" parent="1" vertex="1">
                    <mxGeometry x="20" y="25" width="1360" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Same-Origin nghiêm ngặt hơn, Same-Site rộng rãi hơn" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#cbd5e1;fillColor=none;strokeColor=none;fontFamily=Helvetica;" parent="1" vertex="1">
                    <mxGeometry x="20" y="62" width="1360" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="cardOrigin" value="&lt;b style=&#39;font-size:18px;color:#1e3a8a;&#39;&gt;Same-Origin&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#64748b;font-style:italic;&#39;&gt;Chính sách nghiêm ngặt&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;color:#334155;&#39;&gt;Hai URL được coi là &lt;b&gt;same-origin&lt;/b&gt; khi GIỐNG NHAU cả 3 thành phần:&lt;/span&gt;&lt;br&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;•&amp;nbsp;&lt;b&gt;Scheme&lt;/b&gt; — ví dụ &lt;code&gt;https&lt;/code&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;•&amp;nbsp;&lt;b&gt;Host&lt;/b&gt; bao gồm subdomain — &lt;code&gt;www.example.com&lt;/code&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;•&amp;nbsp;&lt;b&gt;Port&lt;/b&gt; — ví dụ &lt;code&gt;443&lt;/code&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-family:Courier New;background:#dbeafe;padding:8px 12px;border-radius:4px;display:inline-block;&#39;&gt;&lt;b style=&#39;color:#1d4ed8;&#39;&gt;https&lt;/b&gt;&lt;span style=&#39;color:#94a3b8;&#39;&gt;://&lt;/span&gt;&lt;b style=&#39;color:#1d4ed8;&#39;&gt;www.example.com&lt;/b&gt;&lt;span style=&#39;color:#94a3b8;&#39;&gt;:&lt;/span&gt;&lt;b style=&#39;color:#1d4ed8;&#39;&gt;443&lt;/b&gt;&lt;span style=&#39;color:#94a3b8;&#39;&gt;/page&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style=&#39;color:#6b7280;font-size:11px;&#39;&gt;Phần in đậm là phần Same-Origin kiểm tra&lt;/i&gt;" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#f5f9ff;strokeColor=#1d4ed8;strokeWidth=2;shadow=1;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=13;fontColor=#1e3a8a;spacingLeft=20;spacingTop=18;spacingRight=20;" parent="1" vertex="1">
                    <mxGeometry x="20" y="120" width="670" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="cardSite" value="&lt;b style=&#39;font-size:18px;color:#134e4a;&#39;&gt;Same-Site&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#64748b;font-style:italic;&#39;&gt;Chính sách rộng rãi hơn&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;color:#334155;&#39;&gt;Hai URL được coi là &lt;b&gt;same-site&lt;/b&gt; khi cùng &lt;b&gt;registrable domain&lt;/b&gt; (eTLD+1). Subdomain và port KHÔNG quan trọng:&lt;/span&gt;&lt;br&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;•&amp;nbsp;&lt;b&gt;Scheme&lt;/b&gt; — bắt buộc khớp (schemeful same-site)&lt;br&gt;&amp;nbsp;&amp;nbsp;•&amp;nbsp;&lt;b&gt;eTLD+1&lt;/b&gt; — registrable domain &lt;code&gt;example.com&lt;/code&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;•&amp;nbsp;&lt;b&gt;Port&lt;/b&gt; và &lt;b&gt;subdomain&lt;/b&gt; — bỏ qua&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-family:Courier New;background:#ccfbf1;padding:8px 12px;border-radius:4px;display:inline-block;&#39;&gt;&lt;b style=&#39;color:#0f766e;&#39;&gt;https&lt;/b&gt;&lt;span style=&#39;color:#94a3b8;&#39;&gt;://www.&lt;/span&gt;&lt;b style=&#39;color:#0f766e;&#39;&gt;example.com&lt;/b&gt;&lt;span style=&#39;color:#94a3b8;&#39;&gt;:443/page&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style=&#39;color:#6b7280;font-size:11px;&#39;&gt;Phần in đậm là phần Same-Site kiểm tra&lt;/i&gt;" style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;fillColor=#f0fdfa;strokeColor=#0f766e;strokeWidth=2;shadow=1;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=13;fontColor=#134e4a;spacingLeft=20;spacingTop=18;spacingRight=20;" parent="1" vertex="1">
                    <mxGeometry x="710" y="120" width="670" height="280" as="geometry"/>
                </mxCell>
