                <!-- Title -->
                <mxCell id="title" value="🐘 POSTGRES EXPORT — COMPONENT ARCHITECTURE: TRADITIONAL vs STREAMING" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;fontColor=#0F172A;fontFamily=Helvetica;" parent="1" vertex="1">
