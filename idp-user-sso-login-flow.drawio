        <mxCell id="m19_note" value="Pins lockout 99 years in the future → effectively blocks username/password sign-in for this SSO-provisioned user.&#10;After this call, LoginSso also sets user.PasswordHash = string.Empty in memory." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
