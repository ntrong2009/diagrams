        <mxCell id="m1" value="1: POST /users/sso-login &#10;Header: Authorization (or IAP signed header) carries the SSO/GCIP JWT" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=11;" edge="1" parent="1">
