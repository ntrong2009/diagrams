<mxfile host="65bd71144e">
    <diagram name="Nginx Reverse Proxy — component diagram" id="nginx-reverse-proxy-utilities">
        <mxGraphModel dx="2522" dy="827" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="Nginx reverse proxy — component diagram (proxy_pass, proxy_cache, timeouts)" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="150" y="20" width="1200" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="c_client" value="&lt;b&gt;Client&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px&quot;&gt;«component»&lt;/i&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Browser / SPA&lt;/span&gt;" style="shape=component;align=center;spacingLeft=24;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="-150" y="145" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="c_nginx" value="Nginx  «component»  (reverse proxy)" style="swimlane;startSize=34;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;arcSize=6;fontSize=14;fontStyle=1;collapsible=0;verticalAlign=top;align=left;spacingLeft=14;" parent="1" vertex="1">
                    <mxGeometry x="360" y="90" width="900" height="750" as="geometry"/>
                </mxCell>
                <mxCell id="n_listen" value="&lt;b&gt;HTTP Listener&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;listen 80 / 443 ssl http2;&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;server_name / routing&lt;/span&gt;" style="shape=component;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;spacingLeft=24;" parent="c_nginx" vertex="1">
                    <mxGeometry x="35" y="60" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="n_timeout" value="&lt;b&gt;Timeout config&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;client_header_timeout 60s&lt;br&gt;client_body_timeout 60s&lt;br&gt;keepalive_timeout 75s&lt;br&gt;proxy_connect_timeout 60s&lt;br&gt;proxy_send_timeout 60s&lt;br&gt;proxy_read_timeout 60s&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;" parent="c_nginx" vertex="1">
                    <mxGeometry x="10" y="205" width="220" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="n_proxypass" value="&lt;b&gt;proxy_pass&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;proxy_pass http://upstream;&lt;br&gt;proxy_set_header Host $host;&lt;br&gt;proxy_set_header X-Real-IP $remote_addr;&lt;br&gt;proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;&lt;/span&gt;" style="shape=component;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;spacingLeft=24;" parent="c_nginx" vertex="1">
                    <mxGeometry x="270" y="205" width="360" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="n_cache" value="&lt;b&gt;proxy_cache module&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;proxy_cache zone1;&lt;br&gt;proxy_cache_methods GET HEAD;&lt;br&gt;proxy_cache_key &quot;$scheme$proxy_host$request_uri&quot;;&lt;br&gt;proxy_cache_valid 200 302 10m; 404 1m;&lt;br&gt;adds header X-Cache: HIT | MISS&lt;/span&gt;" style="shape=component;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;spacingLeft=24;" parent="c_nginx" vertex="1">
                    <mxGeometry x="580" y="40" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="n_keepalive" value="&lt;b&gt;upstream keepalive pool&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;upstream app { server …; keepalive 32; }&lt;br&gt;reuse TCP cho request sau&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=center;spacingLeft=8;spacingRight=8;" parent="c_nginx" vertex="1">
                    <mxGeometry x="290" y="420" width="510" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="n_flow_title" value="Request flow" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=8;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="c_nginx" vertex="1">
                    <mxGeometry x="290" y="510" width="510" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="n_f1" value="&lt;b&gt;① accept &amp; parse&lt;/b&gt; HTTP request từ client&#xa;(áp client_header_timeout / client_body_timeout)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;" parent="c_nginx" vertex="1">
                    <mxGeometry x="290" y="545" width="510" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n_f2" value="&lt;b&gt;② cache lookup&lt;/b&gt; (chỉ GET/HEAD) → HIT: trả ngay · MISS / EXPIRED: tiếp tục" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;" parent="c_nginx" vertex="1">
                    <mxGeometry x="290" y="595" width="510" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="n_f3" value="&lt;b&gt;③ proxy_pass&lt;/b&gt; đến upstream&#xa;(áp proxy_connect_timeout → proxy_send_timeout → proxy_read_timeout)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;" parent="c_nginx" vertex="1">
                    <mxGeometry x="290" y="635" width="510" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n_f4" value="&lt;b&gt;④ store to cache&lt;/b&gt; (nếu response cacheable theo proxy_cache_valid) → trả client · giữ kết nối theo keepalive_timeout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=8;" parent="c_nginx" vertex="1">
                    <mxGeometry x="290" y="685" width="510" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n_snippet" value="&lt;b&gt;Config snippet (location block)&lt;/b&gt;&#xa;location / {&#xa;    proxy_pass http://app;&#xa;    proxy_cache zone1;&#xa;    proxy_cache_methods GET HEAD;&#xa;    proxy_cache_valid 200 302 10m;&#xa;    proxy_cache_key &quot;$scheme$proxy_host$request_uri&quot;;&#xa;    add_header X-Cache $upstream_cache_status;&#xa;    proxy_connect_timeout 60s;&#xa;    proxy_send_timeout    60s;&#xa;    proxy_read_timeout    60s;&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f8f8;strokeColor=#b5b5b5;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" parent="c_nginx" vertex="1">
                    <mxGeometry x="20" y="425" width="250" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="e_listen_cache" value="GET/HEAD" style="endArrow=classic;html=1;endFill=1;strokeColor=#82b366;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" parent="c_nginx" source="n_listen" target="n_cache" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_cache_proxypass" value="MISS / non-cacheable" style="endArrow=classic;html=1;endFill=1;strokeColor=#82b366;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" parent="c_nginx" source="n_cache" target="n_proxypass" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_listen_proxypass" value="POST / PUT / DELETE" style="endArrow=classic;html=1;endFill=1;strokeColor=#82b366;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" parent="c_nginx" source="n_listen" target="n_proxypass" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_timeout_listen" value="«apply»" style="endArrow=open;html=1;endFill=0;dashed=1;strokeColor=#d79b00;strokeWidth=1.2;fontSize=10;labelBackgroundColor=#ffffff;entryX=0.473;entryY=0.989;entryDx=0;entryDy=0;entryPerimeter=0;" parent="c_nginx" source="n_timeout" target="n_listen" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_timeout_proxypass" value="«apply»" style="endArrow=open;html=1;endFill=0;dashed=1;strokeColor=#d79b00;strokeWidth=1.2;fontSize=10;labelBackgroundColor=#ffffff;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" parent="c_nginx" source="n_timeout" target="n_proxypass" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_cache_store" value="&lt;b&gt;proxy_cache_path&lt;/b&gt; (disk / tmpfs)&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;/var/cache/nginx  keys_zone=zone1:10m  inactive=60m  max_size=1g&lt;/span&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1670" y="145" width="320" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="c_upstream" value="&lt;b&gt;Upstream&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px&quot;&gt;«component»&lt;/i&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;App server (.NET / Node / ...)&lt;/span&gt;" style="shape=component;align=center;spacingLeft=24;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1290" y="315" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="e_client_nginx" value="&lt;b&gt;HTTP / HTTPS&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;client_header_timeout 60s · client_body_timeout 60s&lt;br&gt;keepalive_timeout 75s (reuse TCP)&lt;/span&gt;" style="endArrow=classic;html=1;startArrow=classic;startFill=1;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;" parent="1" source="c_client" target="n_listen" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_nginx_upstream" value="&lt;b&gt;HTTP (proxy_pass)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;proxy_connect_timeout 60s · proxy_send_timeout 60s&lt;br&gt;proxy_read_timeout 60s&lt;/span&gt;" style="endArrow=classic;html=1;startArrow=classic;startFill=1;endFill=1;strokeColor=#b85450;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="n_proxypass" target="c_upstream" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_cache_store" value="&lt;b&gt;lookup / store&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;key = $scheme$proxy_host$request_uri · TTL từ proxy_cache_valid&lt;/span&gt;" style="endArrow=classic;html=1;startArrow=classic;startFill=1;endFill=1;strokeColor=#d79b00;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;dashed=1;entryPerimeter=0;" parent="1" source="n_cache" target="c_cache_store" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&#xa;• «component» = Nginx module hoặc external service&#xa;• ─────  luồng chính (HTTP / proxy_pass)&#xa;• ─ ─ ─  phụ thuộc cấu hình («apply») hoặc lookup cache&#xa;• Màu xanh dương = client-side · xanh lá = Nginx · cam = cache · đỏ = upstream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="360" y="860" width="560" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="resp_note" value="&lt;b&gt;Response path&lt;/b&gt;&#xa;Upstream → Nginx (proxy_cache store nếu cacheable) → Client&#xa;Nginx thêm header: X-Cache: $upstream_cache_status (HIT / MISS / EXPIRED / BYPASS / STALE)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingTop=6;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="940" y="860" width="480" height="110" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>