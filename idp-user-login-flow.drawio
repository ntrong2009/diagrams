        <mxCell id="m4_note" value="If currentOrigin.IsAdminPortal AND user has no privileged claim (PermissionConst.ExcludedPermissions)&#10;  → throw LOGIN_UNAUTHORIZED (401) — blocks normal users from the admin portal" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
