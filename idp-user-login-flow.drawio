            <mxPoint x="360" y="250" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="m1_note" value="[OriginFilter] [AllowAnonymous]&#10;If !AppSettings.LoginWithUsernamePasswordEnabled → return 403 &#10;&quot;Username/password login is no longer supported…&quot;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="260" width="420" height="50" as="geometry"/>
        </mxCell>

