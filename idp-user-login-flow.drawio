        <!-- ==================== PHASE 3: PASSWORD SIGN-IN ==================== -->
        <mxCell id="p3_hdr" value="Phase 3 — Password sign-in &amp; lockout handling" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="650" width="1470" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="m3_1" value="8: signInManager.PasswordSignInAsync(user, form.Password, isPersistent=true, lockoutOnFailure=true)" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="700" as="sourcePoint"/>
            <mxPoint x="800" y="700" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="m3_2" value="9: Verify password hash + update AccessFailedCount / LockoutEnd" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="740" as="sourcePoint"/>
            <mxPoint x="1460" y="740" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="m3_3" value="10: OK" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1460" y="780" as="sourcePoint"/>
            <mxPoint x="800" y="780" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="m3_4" value="11: SignInResult (Succeeded / LockedOut / Failed)" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="800" y="820" as="sourcePoint"/>
            <mxPoint x="580" y="820" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="m3_note" value="If !signInResult.Succeeded:&#10;  • user.LockoutEnabled=true (save) if not already&#10;  • IsLockedOut → throw ACCOUNT_IS_LOCKED_FOR_30_MINUTES or ACCOUNT_WAITING_FOR_X_MINUTES_TO_LOGIN&#10;  • remainingAttempts ≤ 3 → throw ACCOUNT_LOG_IN_ATTEMPTS_REMAINING&#10;  • otherwise → throw CREDENTIALS_INVALID   (all return 401 to client)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="440" y="840" width="720" height="75" as="geometry"/>
        </mxCell>

