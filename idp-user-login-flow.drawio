        <!-- ==================== PHASE 1: REQUEST ==================== -->
        <mxCell id="p1_hdr" value="Phase 1 — HTTP request &amp; gate" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;spacingLeft=8;" vertex="1" parent="1">
