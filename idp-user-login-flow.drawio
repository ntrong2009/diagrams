        <mxCell id="m2_3" value="5: SELECT * FROM users WHERE normalized_user_name = @u" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#333333;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
